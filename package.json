{
  "name": "assignment-5",
  "version": "1.0.0",
  "description": "Backend project generated by Apollo Gears CLI",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "postinstall": "npm run build",
    "start": "tsx src/server.ts",
    "build": "prisma generate && tsup src/server.ts src/app.ts --format esm --clean",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint ./src/**/*",
    "migrate": "prisma migrate dev",
    "generate": "prisma generate",
    "db:seed": "tsx src/app/utils/seed.ts",
    "studio": "prisma studio",
    "push": "prisma db push",
    "pull": "prisma db pull",
    "lint:fix": "eslint src/**/*.ts --fix",
    "stripe:webhook": "stripe listen --forward-to localhost:5000/webhook",
    "format": "prettier --write ."
  },
  "keywords": [
    "express",
    "prisma",
    "typescript",
    "apollo-gears"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.5.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.2",
    "pg": "^8.19.0",
    "stripe": "^20.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "prisma": "^7.4.2",
    "ts-node-dev": "^2.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
